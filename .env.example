# Copy to .env — never commit real secrets (SEC-7).
# Dev defaults are safe: every third-party integration runs in stub mode, so the app
# boots end-to-end with no external credentials. See docs/TESTING_STRATEGY.md §12.

# ── Django core ────────────────────────────────────────────────────────────────
# DJANGO_SECRET_KEY is REQUIRED in production (config.settings.production has no default).
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# ── Datastores ─────────────────────────────────────────────────────────────────
# In docker-compose these are injected; for bare-metal dev fill them in.
DATABASE_URL=postgres://shoghl:shoghl@localhost:5432/shoghl
CACHE_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Namespaces cache + Celery keys so multiple deploys can share one Redis.
REDIS_PREFIX=shogl

# Read-only connection to the legacy WordPress MySQL, used ONLY by `manage.py import_from_legacy`
# (one-time data migration). Leave blank in normal operation. Example:
# LEGACY_DATABASE_URL=mysql://user:password@host.docker.internal:3307/shogl
LEGACY_DATABASE_URL=

# Trusted reverse-proxy depth for DRF client-IP resolution (rate limits + audit IP). Set to the
# real number of proxies in front of the app (1 = a single nginx/LB). A wrong value lets a spoofed
# X-Forwarded-For bypass the per-IP throttles (e.g. the email-OTP rate limits).
DRF_NUM_PROXIES=1

# ── CORS / CSRF ────────────────────────────────────────────────────────────────
# Dev allows all origins (the API is JWT/Bearer, no cookies). Production defaults to
# False and restricts to CORS_ALLOWED_ORIGINS.
CORS_ALLOW_ALL_ORIGINS=1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
# Public base URL of the SPA. Used to build absolute links in emails, notifications and
# referral links. MUST be set to the real domain in production or links point at localhost.
FRONTEND_URL=http://localhost:3000

# ── Google SSO (FR-AUTH-1) ───────────────────────────────────────────────────────
# Create an OAuth 2.0 Web Client at console.cloud.google.com. Leave empty in dev to
# use the stub login button (GOOGLE_AUTH_STUB=1). NEVER enable the stub in production.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_AUTH_STUB=1

# ── Staff 2FA (FR-AUTH-8) ────────────────────────────────────────────────────────
# Require a verified TOTP device for any staff member to use the admin. Keep 1 in
# staging/production; dev/test default to 0 (password-only admin) for convenience.
ADMIN_OTP_REQUIRED=1

# ── PayPal — the only payment gateway (product decision) ─────────────────────────
# Leave stub on for dev (full flow, no network). Set STUB=0 + creds for sandbox/live.
PAYPAL_STUB=1
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# ── Real-time + push adapters (stub-by-default) ──────────────────────────────────
FIRESTORE_STUB=1   # chat mirror (SRS §10.4) — set 0 + creds for real Firestore
FCM_STUB=1         # push notifications (FR-NOT-2) — set 0 + creds for real FCM

# ── Firebase (real-time chat lives in Firestore; backend is the control plane) ─────
FIREBASE_PROJECT_ID=                # e.g. shoghlonline-prod
FIREBASE_CREDENTIALS=               # path to service-account JSON, or the JSON inline
FIREBASE_WEB_API_KEY=               # public web API key for the Firebase JS SDK
CHAT_SYNC_SECRET=                   # shared secret the Firestore→PG sync presents to /chat/sync

# ── File storage (attachments). Local filesystem by default; set USE_S3=1 + creds in prod ──
USE_S3=0
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=                 # set for MinIO/S3-compatible; leave blank for AWS S3
AWS_S3_REGION_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Observability & logging (Part 10) ─────────────────────────────────────────────
# Structured JSON logs in prod (json) vs human-readable in dev (plain). Secrets/PANs/tokens
# are always redacted regardless of format.
DJANGO_LOG_FORMAT=plain
# Sentry — only initializes when a DSN is set (dev/test/CI stay no-ops). PII is never sent.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Email ────────────────────────────────────────────────────────────────────────
# Dev/test leave EMAIL_BACKEND unset → console backend (mails print to stdout).
# Production: switch to the SMTP backend and fill the host/credentials below.
# Hostinger: smtp.hostinger.com, port 465 + EMAIL_USE_SSL=True (or 587 + EMAIL_USE_TLS=True).
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.hostinger.com
# EMAIL_PORT=465
# EMAIL_USE_SSL=True
# EMAIL_USE_TLS=False
# EMAIL_HOST_USER=info@shoghlonline.com
# EMAIL_HOST_PASSWORD=your-mailbox-password
# DEFAULT_FROM_EMAIL must be a real mailbox/alias on the domain (Hostinger rejects mismatches).
DEFAULT_FROM_EMAIL=شغل أونلاين <no-reply@shoghlonline.com>

# ── Frontend (Next.js) ───────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Canonical public origin (NO trailing slash). DRIVES every canonical tag, the sitemap, robots.txt
# and OG URLs — if it's unset the build bakes in http://localhost:3000, which would deindex the site.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Comma-separated official social profile URLs → Organization.sameAs (Knowledge Panel).
NEXT_PUBLIC_SOCIAL_LINKS=
# GA4 Measurement ID (G-XXXXXXXXXX). Empty → analytics fully off (no gtag, no requests).
NEXT_PUBLIC_GA_ID=
# Google Search Console HTML-tag verification token (the content="..." value of the meta tag GSC
# gives you). Renders <meta name="google-site-verification">. Empty → tag omitted.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools verification token (msvalidate.01). Empty → tag omitted.
NEXT_PUBLIC_BING_SITE_VERIFICATION=
