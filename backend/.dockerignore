# Build-context hygiene — keep host-only artifacts out of the image.
.git/
.gitignore
__pycache__/
*.pyc
*.pyo

# Secrets must never enter the image (env comes from the platform).
.env
.env.*
config/firebase-credentials.json
*firebase*credential*.json
*service-account*.json

# Created at runtime in the container (entrypoint collectstatic + uploaded media volume).
staticfiles/
media/

# Local DB / scratch state.
db.sqlite3
_seedcheck.sqlite3*
celerybeat-schedule
backups/
*.dump

# Test & lint caches / coverage.
.pytest_cache/
.ruff_cache/
pytest-cache-files-*/
.coverage
.coverage.*
coverage.xml
htmlcov/
